---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+973", label: "BH +973" },
  { code: "+91",  label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44",  label: "GB +44" },
  { code: "+1",   label: "US +1" },
]

const benefits = [
  { icon: "🎓", title: "Employment in the UAE", desc: "Professionals hired in the UAE must get a certificate of equivalency for educational degrees obtained outside the UAE from the Ministry of Education (MOE). It confirms your qualifications meet UAE standards." },
  { icon: "🏗️", title: "Engineering and Licensed Professions", desc: "Civil engineers and other licensed professionals must demonstrate the legitimacy of their academic qualifications. The equivalency certificate is required when acquiring an engineering card in Abu Dhabi via the Engineer Registration System." },
  { icon: "📋", title: "Ministry of Education Recognition", desc: "The MOE certifies a degree as equivalent to UAE standards through the equivalency process, which may involve two or three levels of attestations from government departments in both countries." },
  { icon: "✅", title: "Legal Compliance", desc: "Having an equivalency certificate ensures your documents meet the necessary legal requirements for the UAE, protecting you from complications in employment, licensing, or residency applications." },
]

const documents = [
  { title: "Original Degree Certificate", body: "Your original degree certificate from the issuing university or institution, required for verification and attestation before equivalency submission." },
  { title: "Academic Transcripts", body: "Official transcripts showing your full academic record, grades, and subjects studied, as required by the UAE Ministry of Education." },
  { title: "Passport Copy", body: "A clear copy of your valid passport, including the bio-data page and any relevant UAE visa or residency pages." },
  { title: "Prior Attestations (if any)", body: "Any existing attestations or legalizations you have already completed on your documents. Index will review these to identify any further steps required." },
  { title: "Application Form", body: "The completed application form as required by the UAE Ministry of Education equivalency committee, filled out accurately and signed." },
  { title: "Additional Supporting Documents", body: "Depending on the issuing country and institution, additional documents such as course syllabi, institution accreditation proof, or DataFlow verification may be requested." },
]

const pccAssistance = [
  { title: "Faster Approval", desc: "Index reviews your documents, prepares required attestations, and guides you through ministry submissions in an organised manner, reducing delays and shortening your overall processing time." },
  { title: "Rejected Application Recovery", desc: "If your application was previously rejected, Index assesses the reason, identifies missing or incorrect documents, and helps you reapply with the proper requirements." },
  { title: "Full Attestation Management", desc: "Index manages the entire preparation phase including attestation, legalization, and verification steps that must be completed before your certificate can be submitted to the ministry." },
  { title: "Academic + Equivalency in One", desc: "Index handles academic attestation from the issuing country and continues with equivalency submission in the UAE, providing full-service support from start to finish." },
  { title: "Ministry Standards Compliance", desc: "Index checks authenticity, formatting, attestations, and supporting documentation to ensure everything aligns with UAE Ministry of Education standards before submitting your file." },
]

const whyIndex = [
  "Our team reviews your degree details, issuing country, and accreditation status to confirm eligibility before starting the process.",
  "Index manages every step — from attestation in your home country to final equivalency submission in the UAE.",
  "We handle complex cases including degrees from institutions that may require additional supporting documentation.",
  "Index can assist if your equivalency application was previously delayed or rejected, correcting and resubmitting your file.",
  "We guide you through DataFlow and other verification procedures that the ministry may request.",
  "Index evaluates non-accredited institution cases individually and advises on alternatives or supporting documents.",
  "Our professionals ensure your documents meet UAE Ministry of Education formatting and attestation requirements.",
  "We save you time and effort by managing all government department interactions on your behalf.",
  "With 25+ years of experience, Index has considerable knowledge of UAE ministry procedures and requirements.",
  "We offer personalised consultation to assess your specific situation before committing to the full process.",
]

const faqs = [
  {
    q: "How does Index help me get my UAE Equivalency Certificate approved faster?",
    a: "Index streamlines each stage of the process by reviewing your documents, preparing required attestations, and guiding you through ministry submissions. This organised approach reduces delays and helps you receive your equivalency certificate in a shorter timeframe."
  },
  {
    q: "Can Index assist if my equivalency application was previously rejected?",
    a: "Yes. Index can assess the reason for rejection, identify missing or incorrect documents, and help you reapply with the proper requirements so your application aligns with ministry expectations."
  },
  {
    q: "Does Index handle attestation and verification needed before applying for equivalency?",
    a: "Index manages the entire preparation phase, including attestation, legalization, and verification steps that must be completed before the certificate can be submitted to the ministry."
  },
  {
    q: "What documents should I prepare before contacting Index for equivalency services?",
    a: "You can keep your degree certificate, transcript, passport copy, and any prior attestations ready. Index will review these documents and inform you if anything additional is required."
  },
  {
    q: "Can Index manage both academic attestation and UAE Equivalency Certificate submission?",
    a: "Yes. Index can take care of academic attestation from the issuing country and continue with the equivalency submission in the UAE, providing full-service support from start to finish."
  },
  {
    q: "Does Index support equivalency processing for degrees from non-accredited universities?",
    a: "Index evaluates each case individually. If your institution is not recognised, they will guide you on what alternatives or supporting documents may be needed to complete the process."
  },
  {
    q: "How does Index ensure my documents meet UAE Ministry of Education requirements?",
    a: "Index checks authenticity, formatting, attestations, and supporting documentation to ensure everything aligns with ministry standards before submitting your file."
  },
  {
    q: "Can Index guide me on DataFlow or verification steps required for equivalency?",
    a: "Yes. Index can help you understand the verification procedures that the ministry may request and assist you in completing them correctly."
  },
  {
    q: "What makes Index a trusted choice for UAE degree equivalency services?",
    a: "Index offers years of experience, process knowledge, and personalised support. Their team handles complex cases and ensures each step is completed accurately to avoid unnecessary delays."
  },
  {
    q: "Does Index offer consultation to check if my degree qualifies for UAE equivalency?",
    a: "Yes. You can request a consultation, and Index will review your degree details, issuing country, and accreditation status to confirm your eligibility before starting the process."
  },
]
---

<BaseLayout
  title="Equivalency Certificate UAE — Index Office Services"
  description="Convenient, budget-friendly UAE Equivalency Certificate services. 25+ years of experience. Professional degree equivalency assistance by Index Office Services."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .benefit-card-light { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; transition: all 0.25s; }
  .benefit-card-light:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .doc-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 24px; transition: all 0.25s; }
  .doc-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .assist-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; transition: all 0.25s; }
  .assist-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .faq-item { border: 1px solid #eef0f6; border-radius: 14px; overflow: hidden; }
  .faq-item summary { list-style: none; cursor: pointer; padding: 18px 22px; font-size: 0.88rem; font-weight: 700; color: #1A202C; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: "+"; font-size: 1.2rem; font-weight: 900; color: #38B2AC; flex-shrink: 0; }
  .faq-item[open] summary::after { content: "−"; }
  .faq-item[open] { border-color: #B2F5EA; }
  .faq-body { padding: 0 22px 18px; font-size: 0.82rem; color: #4B5563; line-height: 1.75; }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-50.jpg"
    alt="Equivalency Certificate UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      EQUIVALENCY CERTIFICATE<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      The UAE Ministry of Education certifies a degree as equivalent to UAE standards through the certificate equivalency process. It involves two or three levels of attestation from government departments in both countries, followed by a review by an equivalence committee, after which the letter of equivalency is issued.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is a UAE Equivalency Certificate?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
        A UAE Equivalency Certificate is an official recognition from the UAE Ministry of Education (MOE) that your degree obtained outside the UAE meets UAE educational standards. It is a mandatory requirement for professionals seeking employment, licensing, or registration in the UAE.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
        The process involves multiple levels of attestation from government departments in both the issuing country and the UAE, followed by a review by the ministry's equivalence committee before the letter of equivalency is issued.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Issued by the UAE Ministry of Education</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          The equivalency certificate is issued by the UAE MOE and is required for employment, professional licensing (including engineering registration), and compliance with UAE legal requirements for foreign-educated professionals.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-56.jpg" alt="Equivalency Certificate UAE" style="width:100%;height:440px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Professional Equivalency Certificate Assistance</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">End-to-end support by Index Office Services</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ BENEFITS ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-7.jpg" alt="Benefits of Equivalency Certificate UAE" style="width:100%;height:440px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Benefits of Equivalency Certificate</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Employment · Licensing · Compliance · Recognition</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Why You Need It</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 18px;">What Are the Benefits of an Equivalency Certificate?</h2>
        <div style="display:flex;flex-direction:column;gap:14px;" class="four-col">
          {benefits.map(b => (
            <div class="benefit-card-light" style="display:flex;gap:16px;align-items:flex-start;">
              <div style="font-size:1.5rem;flex-shrink:0;">{b.icon}</div>
              <div>
                <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 5px;">{b.title}</h3>
                <p style="font-size:0.9rem;color:#4B5563;line-height:1.6;margin:0;">{b.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENTS REQUIRED ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-41.jpg" alt="Documents required for Equivalency Certificate" style="width:100%;height:220px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Requirements</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Documents Required for Equivalency Certificate</h2>
      </div>
    </div>

    <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
      {documents.map(d => (
        <div class="doc-card">
          <h3 style="font-size:0.92rem;font-weight:800;color:#1A202C;margin:0 0 10px;border-left:3px solid #38B2AC;padding-left:10px;">{d.title}</h3>
          <p style="font-size:0.98rem;color:#4B5563;line-height:1.7;margin:0;">{d.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE ASSISTANCE ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1.4fr 0.9fr;gap:48px;align-items:center;margin-bottom:48px;">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Professional Assistance</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Why Choose Index for Equivalency Certificate?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;">
          By availing the services of Index, you can obtain your Equivalency Certificate, save time and effort, and ensure that your documents meet the necessary legal requirements for the UAE. Index manages every stage — from attestation and verification to final ministry submission — giving you peace of mind throughout the process.
        </p>
      </div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-22.jpg" alt="Equivalency Certificate assistance UAE" style="width:100%;height:260px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.7) 100%);"></div>
        <div style="position:absolute;bottom:16px;left:16px;right:16px;">
          <p style="color:#fff;font-size:0.98rem;font-weight:800;margin:0;">Full Process Handled for You</p>
        </div>
      </div>
    </div>

    <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
      {pccAssistance.map(a => (
        <div class="assist-card">
          <h3 style="font-size:0.92rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:10px;">{a.title}</h3>
          <p style="font-size:0.98rem;color:#4B5563;line-height:1.7;margin:0;">{a.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ HOW INDEX HELPS ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
        <img src="/images/img-3.jpg" alt="Index Office Services team" style="width:100%;height:340px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">Index Office Services</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">25+ Years · UAE Equivalency Experts</p>
        </div>
      </div>
      <div>
        <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Why Choose Us</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.2;margin:0 0 16px;">How Can Index Assist You?</h2>
        <p style="color:#B2F5EA;font-size:1.05rem;line-height:1.8;margin-bottom:16px;">
          Index is a specialist service provider with over 25 years of experience in UAE document services. We offer comprehensive assistance for obtaining your Equivalency Certificate — from initial consultation and document review to attestation, ministry submission, and final delivery.
        </p>
        <p style="color:#94A3B8;font-size:1rem;line-height:1.8;">
          Our personalised approach ensures that your specific case is handled accurately, whether your degree is from a recognised institution or one that requires additional supporting documentation. Call us today for a free consultation.
        </p>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:52px;" class="two-col">
      {whyIndex.map(point => (
        <div style="display:flex;align-items:flex-start;gap:12px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:16px;">
          <span style="color:#38B2AC;font-weight:900;font-size:1rem;flex-shrink:0;margin-top:1px;">→</span>
