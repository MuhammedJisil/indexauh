---
import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+973", label: "BH +973" },
  { code: "+91",  label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44",  label: "GB +44" },
  { code: "+1",   label: "US +1" },
]

const benefits = [
  { icon: "📜", title: "Power of Attorney", desc: "We simplify drafting of both special and general power of attorney documents through online notary public applications, ensuring your authorization documents are legally valid in the UAE." },
  { icon: "🏢", title: "Company Formation Documents", desc: "Writing, translating, and notarizing memorandums of association, articles of association, and local service agency contracts are all covered by our specialist notary team." },
  { icon: "✅", title: "Ministry of Justice Notarization", desc: "Index specializes in providing all notary public services through the portal of the Judicial Department and other governmental entities in the UAE, ensuring legal compliance." },
  { icon: "🌐", title: "Immigration Document Attestation", desc: "We handle attestation for immigration to Canada, the United Kingdom, Australia, Dominica, and more — certified, fast, and meeting the requirements of each destination country." },
]

const documents = [
  { title: "Memorandum of Association", body: "Required for company formation in the UAE. Index prepares, translates, and notarizes your memorandum of association through official UAE judicial channels." },
  { title: "Power of Attorney", body: "Special or general power of attorney documents, drafted and notarized by our experts through the online portal of the Judicial Department." },
  { title: "Contracts & Agreements", body: "Legal drafting and notarization of all types of contracts, agreements, and memorandums of understanding for business and personal use." },
  { title: "Declarations & Acknowledgements", body: "Official declarations and acknowledgements notarized for use in the UAE and internationally, with certified true copy attestation where required." },
  { title: "Local Service Agent Contracts", body: "Legally binding local service agent contracts required for certain business structures in the UAE, prepared and notarized by Index specialists." },
  { title: "Wills & Probate", body: "Wills registration services by DIFC WPR licensed professionals. Covers Guardianship, Property, Business Owners, Financial Assets, and Full Wills." },
]

const services = [
  { title: "Certified True Copy Attestation", desc: "Fast and reliable certified true copy attestation for passports, utility bills, tenancy contracts, educational certificates, and more. Same-day service available." },
  { title: "Credit Card & Debt Settlement", desc: "Dedicated debt counseling and bank negotiation services. Index helps resolve credit card and bank debts amicably, avoiding legal action, travel bans, and credit score damage." },
  { title: "Debt Collection", desc: "Cost-effective professional debt collection using reminder calls, AI-powered automation, and legal letters — turning bad debts into credits without costly litigation." },
  { title: "Cheque Bounce Resolution", desc: "Expert guidance and support for cheque bounce complaints, litigation, criminal court, and civil cases — including assistance for defaulters returning to the UAE." },
  { title: "Property Document Legalization", desc: "End-to-end drafting and legalization of property sale and purchase documents, ensuring legal compliance for UAE real estate transactions." },
  { title: "Legal Translation Services", desc: "Professional translation of legal documents for notarization and attestation, with full compliance to UAE judicial and ministry requirements." },
]

const whyIndex = [
  "Our team reviews your documents and advises on the exact notarization path required before starting any process.",
  "Index processes all notary services directly through the UAE Judicial Department portal and official government channels.",
  "We handle both simple and complex documents, including translated, multi-party, and foreign-origin contracts.",
  "Index assists clients whose documents were previously rejected or returned by authorities with incomplete attestation.",
  "We coordinate certified true copy attestation, legalization, and authentication for international use in over 20 countries.",
  "Our debt negotiation specialists liaise with banks on your behalf to waive penal interest, delay charges, and legal fees.",
  "Index manages cheque bounce situations with police, criminal court, and civil courts — including for returning UAE residents.",
  "We prepare and register wills under DIFC WPR license, covering all five will types for UAE residents and expats.",
  "With 25+ years of experience, Index has in-depth knowledge of UAE notary, legal, and attestation procedures.",
  "Free initial consultation available — we assess your situation before recommending any service or commitment.",
]

const faqs = [
  {
    q: "What types of documents can Index notarize in the UAE?",
    a: "Index handles notarization of memorandums of association, power of attorney (special and general), contracts, agreements, declarations, acknowledgements, local service agent contracts, and wills — all processed through the UAE Judicial Department portal."
  },
  {
    q: "How does Index help with Power of Attorney drafting and notarization?",
    a: "Index drafts both special and general power of attorney documents and processes them through the online portal of the Judicial Department, ensuring legal validity for use in the UAE and internationally."
  },
  {
    q: "Can Index assist with certified true copy attestation for passports and other documents?",
    a: "Yes. Index provides fast and reliable certified true copy attestation for passports, utility bills, tenancy contracts, educational certificates, and other documents. Same-day service is available in many cases."
  },
  {
    q: "What is the process for attesting documents for immigration to countries like Canada or Australia?",
    a: "Index manages the full attestation chain for immigration documents destined for Canada, the United Kingdom, Australia, Dominica, and other countries — including home country ministry attestation and UAE MOFA legalization where required."
  },
  {
    q: "Can Index help me settle my credit card debt or negotiate with my bank?",
    a: "Yes. Index has a dedicated department for bank and credit card debt negotiation. Their specialists assess your financial situation and liaise with banks to arrange repayment, waive penalty charges, and help you avoid legal action or travel bans."
  },
  {
    q: "What services does Index provide for cheque bounce cases?",
    a: "Index provides guidance and support for cheque bounce complaints, criminal court cases, and civil disputes. They also assist defaulters returning to the UAE in resolving outstanding cheque bounce issues with police and courts."
  },
  {
    q: "Does Index offer will registration services in the UAE?",
    a: "Yes. Index holds a DIFC WPR license and registers all five types of wills in the UAE — Guardianship, Property, Business Owners, Financial Assets, and Full Wills — for both UAE residents and expatriates."
  },
  {
    q: "How does Index handle debt collection for businesses?",
    a: "Index's debt collection team makes structured reminder calls, sends legal letters, and uses AI-assisted automation to recover debts efficiently. The process prioritizes amicable resolution before escalating to legal action."
  },
  {
    q: "Can Index assist with company formation documents and local service agent contracts?",
    a: "Yes. Index prepares, translates, and notarizes memorandums of association, articles of association, and local service agent contracts required for business setup in the UAE."
  },
  {
    q: "Does Index offer a free consultation before starting notary or attestation services?",
    a: "Yes. Index provides a free initial consultation to assess your documents and requirements before recommending any service or beginning any process. Contact Index today to book your consultation."
  },
]
---

<BaseLayout
  title="Notary Assistance UAE — Index Office Services"
  description="Convenient, budget-friendly notary public services in the UAE. 25+ years of experience. Power of attorney, attestation, company documents, wills, and debt services by Index Office Services."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .benefit-card-light { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; transition: all 0.25s; }
  .benefit-card-light:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .doc-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 24px; transition: all 0.25s; }
  .doc-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .assist-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; transition: all 0.25s; }
  .assist-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); }
  .faq-item { border: 1px solid #eef0f6; border-radius: 14px; overflow: hidden; }
  .faq-item summary { list-style: none; cursor: pointer; padding: 18px 22px; font-size: 0.88rem; font-weight: 700; color: #1A202C; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: "+"; font-size: 1.2rem; font-weight: 900; color: #38B2AC; flex-shrink: 0; }
  .faq-item[open] summary::after { content: "−"; }
  .faq-item[open] { border-color: #B2F5EA; }
  .faq-body { padding: 0 22px 18px; font-size: 0.82rem; color: #4B5563; line-height: 1.75; }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
    .two-col { grid-template-columns: 1fr !important; }
    .four-col { grid-template-columns: 1fr 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=1600&q=80"
    alt="Notary Assistance UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      NOTARY ASSISTANCE<br/>IN THE UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:680px;">
      Notary public applications include memorandum of association, power of attorney, contracts and agreements, declarations, acknowledgements, and local service agent contracts. Index makes it simple to prepare and notarize all documents through the UAE Judicial Department portal in a very short amount of time.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner split-grid" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What Is Notary Assistance in the UAE?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
        Notary assistance in the UAE covers the official preparation, authentication, and legalization of legal documents through the UAE Judicial Department and other government entities. It is a mandatory requirement for company formation, property transactions, power of attorney, wills, and a wide range of personal and business legal matters.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:16px;">
        Index has developed its specialization in providing all notary public services through the portal of the Judicial Department and other governmental entities in the UAE, making it simple for all clients to prepare and notarize documents in a very short amount of time.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Processed via UAE Judicial Department</h3>
        <p style="color:#4B5563;font-size:0.85rem;line-height:1.75;margin:0;">
          All notarizations are processed through official UAE government portals, ensuring your documents carry full legal validity for use in the UAE and internationally.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="https://images.unsplash.com/photo-1568992688065-536aad8a12f6?w=800&q=80" alt="Notary Assistance UAE" style="width:100%;height:440px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Professional Notary Public Assistance</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">End-to-end support by Index Office Services</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ BENEFITS ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=700&q=80" alt="Benefits of Notary Assistance UAE" style="width:100%;height:440px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Key Notary Services</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">POA · Company Docs · Attestation · Wills</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What We Cover</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 18px;">Core Notary Public Applications</h2>
        <div style="display:flex;flex-direction:column;gap:14px;" class="four-col">
          {benefits.map(b => (
            <div class="benefit-card-light" style="display:flex;gap:16px;align-items:flex-start;">
              <div style="font-size:1.5rem;flex-shrink:0;">{b.icon}</div>
              <div>
                <h3 style="font-size:0.88rem;font-weight:800;color:#1A202C;margin:0 0 5px;">{b.title}</h3>
                <p style="font-size:0.78rem;color:#4B5563;line-height:1.6;margin:0;">{b.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENTS / SERVICES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1400&q=80" alt="Notary document services UAE" style="width:100%;height:220px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Document Services</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">Documents We Notarize &amp; Attest</h2>
      </div>
    </div>

    <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
      {documents.map(d => (
        <div class="doc-card">
          <h3 style="font-size:0.92rem;font-weight:800;color:#1A202C;margin:0 0 10px;border-left:3px solid #38B2AC;padding-left:10px;">{d.title}</h3>
          <p style="font-size:0.82rem;color:#4B5563;line-height:1.7;margin:0;">{d.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ OUR SERVICES ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1.4fr 0.9fr;gap:48px;align-items:center;margin-bottom:48px;">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Full Service Range</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Our Services</h2>
        <p style="color:#4B5563;font-size:0.88rem;line-height:1.8;">
          Index provides legal and consulting services at the highest professional level. From certified true copy attestation and immigration document legalization to debt settlement, debt collection, cheque bounce resolution, and wills — our team delivers effective solutions across a wide range of personal and business legal needs.
        </p>
      </div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=700&q=80" alt="Index Office Services UAE" style="width:100%;height:260px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.7) 100%);"></div>
        <div style="position:absolute;bottom:16px;left:16px;right:16px;">
          <p style="color:#fff;font-size:0.82rem;font-weight:800;margin:0;">Comprehensive Legal &amp; Notary Services</p>
        </div>
      </div>
    </div>

    <div class="three-col" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
      {services.map(a => (
        <div class="assist-card">
          <h3 style="font-size:0.92rem;font-weight:800;color:#1A202C;margin:0 0 8px;border-left:3px solid #38B2AC;padding-left:10px;">{a.title}</h3>
          <p style="font-size:0.82rem;color:#4B5563;line-height:1.7;margin:0;">{a.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ HOW INDEX HELPS ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div class="split-grid" style="display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
        <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=700&q=80" alt="Index Office Services team" style="width:100%;height:340px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">Index Office Services</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">25+ Years · UAE Notary Experts</p>
        </div>
      </div>
      <div>
        <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Why Choose Us</p>
        <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.2;margin:0 0 16px;">How Can Index Assist You?</h2>
        <p style="color:#B2F5EA;font-size:0.88rem;line-height:1.8;margin-bottom:16px;">
          Index is a specialist service provider with over 25 years of experience in UAE notary and document services. We offer comprehensive assistance — from initial consultation and document review to notarization, attestation, and final delivery — for individuals and businesses across the UAE.
