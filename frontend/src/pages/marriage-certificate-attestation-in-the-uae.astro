<script>
(function(){
  // Country tabs
  const countryTabs = document.querySelectorAll('#countryTabs .tab-btn');
  countryTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      countryTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const key = (tab as HTMLElement).dataset.country;
      document.querySelectorAll('.country-panel').forEach(panel => {
        panel.classList.toggle('active', panel.id === `country-${key}`);
      });
    });
  });

  // How-to tabs
  const howTabs = document.querySelectorAll('#howTabs .tab-btn');
  howTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      howTabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const target = (tab as HTMLElement).dataset.tab;
      ['issue','gain'].forEach(t => {
        const el = document.getElementById('tab-' + t) as HTMLElement;
        el.style.display = t === target ? 'grid' : 'none';
      });
    });
  });

  // FAQ accordion
  document.querySelectorAll('.faq-item').forEach(item => {
    item.querySelector('.faq-q')?.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(x => {
        x.classList.remove('open');
        (x.querySelector('.faq-a') as HTMLElement).classList.remove('open');
      });
      if (!isOpen) {
        item.classList.add('open');
        (item.querySelector('.faq-a') as HTMLElement).classList.add('open');
      }
    });
  });
})();
</script>

