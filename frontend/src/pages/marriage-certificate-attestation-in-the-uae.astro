  "Country where the marriage certificate was issued",
  "Government and embassy attestation fees",
  "MOFA attestation charges in the UAE",
  "Legal translation requirements, when applicable",
  "Standard or express processing",
  "Courier or document collection and delivery services",
]

const delayReasons = [
  "Name mismatch between the marriage certificate and passport",
  "Spelling differences in the names of either spouse",
  "Damaged, torn, or unreadable marriage certificates",
  "Laminated certificates that are not accepted by certain authorities",
  "Missing government or embassy stamps",
  "Following the attestation process in the wrong order",
  "Incomplete supporting documents",
  "Unregistered or incorrectly issued marriage certificates",
  "Missing legal translation when required",
  "Expired passport or visa copies submitted with the application",
]

const emirates = [
  { title: "Marriage Certificate Attestation Dubai", desc: "Our marriage certificate attestation Dubai service supports residents across the city with end-to-end document handling. From document verification to MOFA marriage certificate attestation, we guide you through each stage and keep you updated throughout the process." },
  { title: "Marriage Certificate Attestation in Abu Dhabi", desc: "We assist with document submission, embassy coordination, and final MOFA attestation based on your certificate's country of issue. We also handle Abu Dhabi marriage certificate attestation requests for both residents and businesses." },
  { title: "Marriage Certificate Attestation Sharjah", desc: "Our marriage certificate attestation Sharjah service is available for individuals and families who need their documents accepted for official use in the UAE. We review every application carefully before submission to help reduce delays and make the process easier from start to finish." },
]

const whyUs = [
  { title: "25+ Years of Experience", desc: "25+ years of experience in document attestation services." },
  { title: "Country-Specific Expertise", desc: "Expert guidance based on your certificate's country of issue." },
  { title: "End-to-End Support", desc: "Complete support from document review to final MOFA attestation." },
  { title: "Translation Under One Roof", desc: "Certified legal translation services under one roof." },
  { title: "Careful Verification", desc: "Careful verification to reduce delays and resubmissions." },
  { title: "Secure Handling", desc: "Secure handling of original documents." },
  { title: "Pickup & Delivery", desc: "Pickup and delivery services across the UAE." },
  { title: "Regular Updates", desc: "Regular updates throughout the attestation process." },
  { title: "Transparent Pricing", desc: "Clear pricing with no hidden charges." },
]

const faqs = [
  { q: "Can I attest a marriage certificate issued many years ago?", a: "Yes. Older marriage certificates can usually be attested as long as they were issued by the appropriate authority and are in good condition. Some cases may require additional verification before the process begins." },
  { q: "Is my presence required during the attestation process?", a: "In most cases, no. The process can often be completed through an authorized representative, provided the required supporting documents are available." },
  { q: "Can I use the same attested marriage certificate for multiple purposes?", a: "Yes. An attested marriage certificate is generally accepted for various official purposes, such as visa applications, banking, insurance, and legal procedures, provided the receiving authority accepts the document." },
  { q: "What should I do if my marriage certificate is damaged or difficult to read?", a: "Damaged or unclear certificates may not be accepted by some authorities. It is usually better to obtain a fresh copy from the issuing authority before starting the attestation process." },
  { q: "Can handwritten marriage certificates be attested?", a: "Acceptance is determined by the issuing country's requirements and the certificate's format. Some handwritten certificates are accepted, while others may require a recently issued computerized version." },
  { q: "Will the attestation expire?", a: "There is usually no set validity period for a completed attestation. However, some authorities may request a recently attested document depending on the purpose of your application." },
  { q: "Can I start the attestation process while I am outside the UAE?", a: "Yes. Many applicants begin the process from their home country before relocating to the UAE. The process varies according to the country that issued the marriage certificate." },
  { q: "Do I need to attest my marriage certificate again if I change my passport?", a: "Generally, no. However, when there is a significant change in your personal details, some authorities may ask for additional supporting documents to establish the connection between your old and new records." },
]
