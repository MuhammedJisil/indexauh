const docsRequired = [
  "Original marriage certificate",
  "Passport copy of both husband and wife",
  "Emirates ID copy, when available",
  "UAE residence visa copy, when applicable",
  "Authorization letter, when someone else is submitting the documents on your behalf",
  "Additional supporting documents requested by the embassy or government authority",
]

const timingFactors = [
  "Country of issue",
  "Government authority processing time",
  "UAE Embassy processing",
  "MOFA attestation in the UAE",
  "Legal translation, when required",
  "Public holidays or embassy closures",
  "Missing or incorrect documents",
]

