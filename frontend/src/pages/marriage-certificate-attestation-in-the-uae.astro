const glance = [
  { label: "Service", value: "Marriage Certificate Attestation" },
  { label: "Purpose", value: "To make your marriage certificate legally valid for official use in the UAE" },
  { label: "Common Uses", value: "Family visa, spouse sponsorship, residence applications, government records, banking, and legal procedures" },
  { label: "Process", value: "Verification → Government Authentication → Marriage Certificate Embassy Attestation → MOFA Marriage Certificate Attestation" },
  { label: "Documents Required", value: "The original marriage certificate, passport copies, a UAE visa or Emirates ID (where applicable), and any additional documents required by the issuing country" },
  { label: "Processing Time", value: "Varies depending on the country of issue and embassy requirements" },
  { label: "Service Coverage", value: "Dubai, Abu Dhabi, Sharjah, and all other Emirates" },
  { label: "Additional Support", value: "Legal translation, document review, pickup and delivery, and status updates" },
]

const whyNeeded = [
  {
    category: "Immigration and Visa Services",
    intro: "An attested marriage certificate is commonly required for:",
    items: [
      "Family residence visa applications",
      "Spouse sponsorship",
      "Dependent visa processing",
      "Marriage certificate attestation for UAE visa applications",
      "Immigration record updates",
    ],
  },
  {
    category: "Government Records",
    intro: "Many government services ask for an attested marriage certificate to verify your marital status. This may include:",
    items: [
      "Registering the birth of a child",
      "Updating personal records with UAE authorities",
      "Completing family-related government procedures",
    ],
  },
  {
    category: "Banking and Financial Services",
    intro: "Some financial institutions request proof of marriage before processing certain applications. An attested certificate may be needed for:",
    items: [
      "Opening a joint bank account",
