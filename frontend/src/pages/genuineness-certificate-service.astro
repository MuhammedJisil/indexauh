      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=700&q=80" alt="Genuineness Certificate assistance UAE" style="width:100%;height:260px;object-fit:cover;display:block;" />
