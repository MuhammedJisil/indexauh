---
import BaseLayout from '../layouts/BaseLayout.astro'

const courses = [
  {
    emoji: '📊',
    title: 'Digital Marketing',
    desc: 'SEO, social media, content strategy, Google Ads, and analytics — a complete career-ready program.',
    lessons: 48,
    level: 'Beginner',
    color: '#E0F2F1',
    badge: 'Popular',
  },
  {
    emoji: '🤖',
    title: 'AI Tools Mastery',
    desc: 'Master ChatGPT, Midjourney, automation tools, and AI workflows to 10x your productivity.',
    lessons: 32,
    level: 'All Levels',
    color: '#FFF3E0',
    badge: 'New',
  },
  {
    emoji: '💻',
    title: 'Web Development',
    desc: 'HTML, CSS, JavaScript, and modern frameworks. Build real websites and web apps from scratch.',
    lessons: 64,
    level: 'Intermediate',
    color: '#F3E5F5',
    badge: null,
  },
  {
    emoji: '🎨',
    title: 'Graphic Design',
    desc: 'Canva, Figma, and Adobe tools. Design logos, banners, social media content, and brand assets.',
    lessons: 36,
    level: 'Beginner',
    color: '#FCE4EC',
    badge: null,
  },
  {
    emoji: '📱',
    title: 'Social Media Management',
    desc: 'Build and manage brand presence across Instagram, LinkedIn, YouTube, and more.',
    lessons: 28,
    level: 'Beginner',
    color: '#E8F5E9',
    badge: null,
  },
  {
    emoji: '💼',
    title: 'Freelancing & Fiverr',
    desc: 'Turn your skills into income. Learn to find clients, write proposals, and grow a freelance career.',
    lessons: 20,
    level: 'All Levels',
    color: '#E3F2FD',
    badge: null,
  },
]
---

<BaseLayout title="Courses – Convex Academy">
  <section class="courses-hero">
    <div class="container">
      <div class="section-badge">Our Programs</div>
      <h1 class="section-title">Courses built for real careers</h1>
      <p class="section-description">
        Every course is designed around job outcomes — not just certificates.
        Learn by doing, with mentors and real projects.
      </p>
    </div>
  </section>

  <section class="courses-grid-section">
    <div class="container">
      <div class="courses-grid">
        {courses.map(course => (
          <div class="course-card">
            <div class="course-icon" style={`background: ${course.color}`}>
              {course.emoji}
            </div>
            <div class="course-meta">
              <span class="level">{course.level}</span>
              {course.badge && <span class={`badge ${course.badge === 'New' ? 'new' : ''}`}>{course.badge}</span>}
            </div>
            <h3>{course.title}</h3>
            <p>{course.desc}</p>
            <div class="course-footer">
              <span class="lessons">{course.lessons} lessons</span>
              <a href="/contact" class="btn btn-primary" style="padding: 10px 20px; font-size: 14px;">Enroll →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .courses-hero {
    padding: 80px 0 40px;
    background: var(--bg-light);
    text-align: center;
  }

  .section-title {
    font-size: 40px;
    font-weight: 700;
    color: var(--text-main);
    line-height: 1.1;
    margin-bottom: 16px;
    letter-spacing: -0.5px;
  }

  .section-description {
    font-size: 17px;
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .courses-grid-section {
    padding: 64px 0 100px;
  }

  .courses-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .course-card {
    background: white;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: all 0.3s ease;
  }

  .course-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(0,191,165,0.25);
  }

  .course-icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
  }

  .course-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .level {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-light);
    padding: 3px 10px;
    border-radius: 100px;
  }

  .badge {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 100px;
    background: var(--primary-light);
    color: var(--primary-dark);
  }

  .badge.new {
    background: #FFF3E0;
    color: #E65100;
  }

  .course-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-main);
    line-height: 1.3;
  }

  .course-card p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .course-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 8px;
  }

  .lessons {
    font-size: 13px;
    color: var(--text-muted);
  }

  @media (max-width: 992px) {
    .courses-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 640px) {
    .courses-grid { grid-template-columns: 1fr; }
    .section-title { font-size: 28px; }
  }
</style>
