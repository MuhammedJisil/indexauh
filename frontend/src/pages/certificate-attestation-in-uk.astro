---
import ContactForm from '../components/ContactForm.astro';

import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1", label: "US +1" },
  { code: "+973", label: "BH +973" },
]

const purposes = [
  { icon: "🛂", title: "Visa & Residency", desc: "Applying for a visa, work permit, residence permit, or citizenship in the UK." },
  { icon: "🏦", title: "Financial & Business", desc: "Opening a bank account, registering a company, or buying a property in the UK." },
  { icon: "🎓", title: "Education & Exams", desc: "Enrolling in an educational institution or taking a professional exam in the UK." },
  { icon: "👪", title: "Family & Civil Matters", desc: "Getting married, divorced, or adopting a child in the United Kingdom." },
  { icon: "💼", title: "Benefits & Inheritance", desc: "Claiming inheritance, pension, or insurance benefits in the UK." },
  { icon: "🪪", title: "Identity & Qualification", desc: "Proving your identity, nationality, qualification, or professional experience in the UK." },
]

const docTypes = [
  { category: "Personal Documents", icon: "👤", docs: ["Birth certificates", "Death certificates", "Marriage certificates", "Civil partnership certificates", "Adoption certificates", "Police clearance certificates"] },
  { category: "Educational Documents", icon: "🎓", docs: ["Educational certificates & diplomas", "Transcripts & mark sheets", "Professional certificates", "Medical certificates & reports", "Professional licenses"] },
  { category: "Legal Documents", icon: "⚖️", docs: ["Power of attorney", "Affidavit", "Will & testament", "Commercial documents & contracts", "Company documents & certificates"] },
]

const steps = [
  { step: "01", title: "Document Submission", desc: "Submit your original documents to Index Office Services. We review them for completeness, accuracy, and suitability before initiating the process." },
  { step: "02", title: "FCDO Apostille", desc: "Your documents are submitted to the UK's Foreign, Commonwealth & Development Office (FCDO) for apostille — an official stamp confirming the document's authenticity." },
  { step: "03", title: "Embassy / Consulate Attestation", desc: "Where required, documents are submitted to the embassy or consulate of the issuing country for counter attestation (legalization) along with supporting documents." },
  { step: "04", title: "Quality Verification", desc: "We verify all stamps, seals, and signatures before returning your documents, ensuring nothing is missing or incorrect." },
  { step: "05", title: "Secure Return", desc: "Your fully attested documents are returned to you safely via secure courier or in-person collection from our offices." },
]

const benefits = [
  { title: "25+ Years of Expertise", desc: "Over two decades of experience handling certificate attestation for the UK, with deep knowledge of FCDO procedures and embassy requirements." },
  { title: "End-to-End Solutions", desc: "We handle all formalities and procedures from start to finish — FCDO apostille, embassy counter attestation, and certified translation if needed." },
  { title: "Safe & Confidential", desc: "Your documents are handled with strict confidentiality, secure physical transfer protocols, and tracked at every stage." },
  { title: "Competitive Pricing", desc: "We offer affordable, transparent pricing with no hidden fees. Flexible payment options are available." },
  { title: "24/7 Customer Support", desc: "Our dedicated support team is available around the clock to answer your queries and provide status updates." },
  { title: "Global Network", desc: "With branches and associates worldwide, we can coordinate UK attestation from anywhere in the world, including the UAE, India, and GCC." },
]

const timingFactors = [
  "The type and number of documents you need to attest",
  "The country where your documents were issued",
  "The authority that issued your documents",
  "The authority that will attest your documents",
  "The method of application and delivery",
]

const faqs = [
  { q: "What is an apostille and do I need one for UK attestation?", a: "An apostille is an official stamped certificate issued by the UK's FCDO that confirms a document is authentic and issued by a recognized authority. It is the first step in UK attestation and is required before embassy or consulate counter-attestation." },
  { q: "How long does UK certificate attestation take?", a: "Processing times vary depending on the document type, originating country, and embassies involved. FCDO apostille typically takes a few working days, while embassy counter-attestation can take 1–15 working days. Index manages the entire process to minimize delays." },
  { q: "Can Index handle attestation on my behalf without me being present?", a: "Yes. Index Office Services can handle the complete attestation process on your behalf with a standard authorization letter. You do not need to be physically present in the UK." },
  { q: "Does my document need to be translated before UK attestation?", a: "If your document is not in English, certified translation may be required. Our team will confirm whether translation is necessary based on your document and the requesting authority's requirements." },
  { q: "What documents do I need to submit along with my main document?", a: "Typically, you will need to submit your original document, a copy of your passport, and an authorization letter if submitting through a representative. Additional supporting documents may be required depending on the embassy or type of attestation needed." },
]
---

<BaseLayout
  title="Certificate Attestation in the UK — Index Office Services"
  description="Fast, reliable, and affordable certificate attestation services in the UK. We handle FCDO apostille, embassy legalization, and all document types. 25+ years of experience."
>

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .purpose-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; transition: all 0.25s; }
  .purpose-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .benefit-card { background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 22px; }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 240px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
    .three-col { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:center;">
  <img
    src="/images/img-32.jpg"
    alt="Certificate Attestation in the UK — London"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 40%;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.92) 0%,rgba(45,55,72,0.80) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:880px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      CERTIFICATE ATTESTATION<br/>IN THE UK
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:660px;">
      If you are planning to visit, study, work, or do business in the UK, you may need to get your documents attested by the UK authorities. Index Office Services handles the complete process — fast, reliable, and hassle-free.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;" class="split-grid">
    <!-- Left text -->
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">What is Certificate Attestation in the UK?</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Certificate attestation is a process of verifying the authenticity of a document by a competent authority. It is required when you want to use a document issued in one country in another country.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Certificate attestation in the UK ensures that your documents are genuine, valid, and recognized by UK authorities. It also prevents fraud, forgery, and misuse of your documents — safeguarding both individuals and institutions.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:20px;">
        The procedure can be long and complex, especially for those unfamiliar with the formalities. Index Office Services handles the complete process quickly and efficiently on your behalf.
      </p>

      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Key Insight — FCDO Apostille</h3>
        <p style="color:#4B5563;font-size:1rem;line-height:1.75;margin:0;">
          UK attestation typically begins with an apostille from the Foreign, Commonwealth &amp; Development Office (FCDO) — an official certificate confirming your document is authentic and issued by a recognized UK authority.
        </p>
      </div>
    </div>

    <!-- Right image -->
    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="/images/img-33.jpg" alt="UK document attestation" style="width:100%;height:420px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">FCDO · Embassy · MOFA</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Complete UK attestation handled end-to-end</p>
        </div>
        <div style="position:absolute;bottom:80px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY GET UK ATTESTATION ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <!-- Split: image + text -->
    <div style="display:grid;grid-template-columns:0.9fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;" class="split-grid">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-34.jpg" alt="London UK certificate purposes" style="width:100%;height:380px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Why UK Attestation Matters</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Visa · Business · Education · Family</p>
        </div>
      </div>
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Core Reasons</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Why Get a Certificate Attestation in the UK?</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;margin-bottom:24px;">
          Certificate attestation in the UK is necessary for a wide range of official purposes. Whether you are relocating, doing business, studying, or dealing with legal matters, your foreign documents must be verified before they are accepted.
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          {purposes.map(p => (
            <div class="purpose-card">
              <div style="font-size:1.6rem;margin-bottom:10px;">{p.icon}</div>
              <h3 style="font-size:1.05rem;font-weight:800;color:#1A202C;margin:0 0 6px;">{p.title}</h3>
              <p style="font-size:0.76rem;color:#4B5563;line-height:1.55;margin:0;">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ DOCUMENT TYPES ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <div style="display:grid;grid-template-columns:1.4fr 0.9fr;gap:48px;align-items:center;margin-bottom:52px;" class="split-grid">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Document Coverage</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Types of Documents That Can Get Certificate Attestation</h2>
        <p style="color:#4B5563;font-size:1.05rem;line-height:1.8;">
          We handle attestation for a wide range of document categories. The list below covers the most commonly requested types. You should always check with the requesting authority to confirm exactly what form of attestation they require.
        </p>
      </div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);">
        <img src="/images/img-23.jpg" alt="Document types for UK attestation" style="width:100%;height:240px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.7) 100%);"></div>
        <div style="position:absolute;bottom:16px;left:16px;right:16px;">
          <p style="color:#fff;font-size:0.98rem;font-weight:800;margin:0;">All Document Categories Covered</p>
        </div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;" class="three-col">
      {docTypes.map(cat => (
        <div style="background:#F8FAFF;border:1px solid #eef0f6;border-radius:16px;padding:28px;">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:18px;">
            <span style="font-size:1.5rem;">{cat.icon}</span>
            <h3 style="font-size:1rem;font-weight:800;color:#1A202C;margin:0;">{cat.category}</h3>
          </div>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:9px;">
            {cat.docs.map(d => (
              <li style="display:flex;align-items:center;gap:8px;font-size:0.98rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">•</span>{d}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ PROCESS STEPS ════ -->
<section style="background:#F0FFFE;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <!-- Image banner -->
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 40px rgba(0,0,0,0.1);margin-bottom:52px;">
      <img src="/images/img-15.jpg" alt="UK attestation process steps" style="width:100%;height:240px;object-fit:cover;object-position:center 35%;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(26,32,44,0.88) 0%,rgba(26,32,44,0.5) 55%,transparent 100%);"></div>
      <div style="position:absolute;top:50%;left:40px;transform:translateY(-50%);">
        <p style="color:#38B2AC;font-weight:700;font-size:0.75rem;letter-spacing:0.12em;text-transform:uppercase;margin:0 0 6px;">Step-by-Step</p>
        <h2 style="color:#fff;font-size:clamp(1.4rem,2.5vw,2rem);font-weight:900;margin:0;max-width:500px;line-height:1.25;">How Long Will It Take &amp; What Does It Involve?</h2>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;" class="split-grid">
      <!-- Steps list -->
      <div style="display:flex;flex-direction:column;gap:14px;">
        {steps.map(s => (
          <div class="step-card">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:1.05rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.9rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Timing info + image -->
      <div>
        <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.12);margin-bottom:24px;">
          <img src="/images/img-16.jpg" alt="Timing factors UK attestation" style="width:100%;height:280px;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 45%,rgba(26,32,44,0.78) 100%);"></div>
          <div style="position:absolute;bottom:18px;left:18px;right:18px;">
            <p style="color:#fff;font-size:1.05rem;font-weight:800;margin:0 0 3px;">Processing Time Varies</p>
            <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">FCDO apostille: 1–5 days · Embassy: 1–15 days</p>
          </div>
        </div>

        <div style="background:#fff;border:1px solid #B2F5EA;border-radius:16px;padding:24px;">
          <h3 style="font-size:0.95rem;font-weight:800;color:#1A202C;margin:0 0 14px;border-left:3px solid #38B2AC;padding-left:12px;">Factors That Affect Processing Time</h3>
          <div style="display:flex;flex-direction:column;gap:9px;">
            {timingFactors.map(f => (
              <div style="display:flex;align-items:center;gap:10px;font-size:0.98rem;color:#4B5563;">
                <span style="color:#38B2AC;font-weight:bold;flex-shrink:0;">→</span>{f}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE INDEX ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <!-- Image + heading row -->
    <div style="display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;margin-bottom:52px;" class="split-grid">
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
        <img src="/images/img-3.jpg" alt="Index Office Services UK attestation team" style="width:100%;height:340px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.75) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 3px;">Index Office Services</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Abu Dhabi · Dubai · Global Network</p>
        </div>
      </div>
