---
import BaseLayout from '../layouts/BaseLayout.astro'

const countryCodes = [
  { code: "+91", label: "IN +91" },
  { code: "+971", label: "AE +971" },
  { code: "+44", label: "GB +44" },
  { code: "+1", label: "US +1" },
  { code: "+973", label: "BH +973" },
]

const services = [
  { icon: "👶", title: "Birth Certificate Attestation", desc: "Required for school admission, visa applications, and dependent sponsorship in the UAE." },
  { icon: "💍", title: "Marriage Certificate Attestation", desc: "Essential for family visa, spouse sponsorship, and dependent residency applications in the UAE." },
  { icon: "📋", title: "Transfer Certificate Attestation", desc: "Needed for school transfers, higher education admission, and academic record verification." },
  { icon: "⚖️", title: "Divorce Certificate Attestation", desc: "Required for legal proceedings, remarriage applications, and change of marital status registration." },
  { icon: "🔒", title: "Single Status Certificate Attestation", desc: "Confirms marital status for marriage registration or immigration purposes in the UAE." },
  { icon: "🕊️", title: "Death Certificate Attestation", desc: "Required for estate proceedings, insurance claims, and legal matters related to the deceased." },
  { icon: "🏥", title: "Medical Certificate Attestation", desc: "Needed for healthcare employment, medical licensing, and professional registration in UAE." },
  { icon: "📜", title: "Affidavit Attestation", desc: "Legal verification of sworn declarations used in official proceedings and administrative processes." },
]

const steps = [
  { step: "01", title: "Document Review", desc: "We carefully check your personal document for accuracy, completeness, and suitability for attestation before submission." },
  { step: "02", title: "Notarization", desc: "Documents are first validated by a certified public notary, adding basic legal weight required for further processing." },
  { step: "03", title: "Home Country Authentication", desc: "The issuing authority, ministry, or government department in your home country verifies the document's authenticity." },
  { step: "04", title: "UAE Embassy Attestation", desc: "The UAE Embassy in the document's country of origin stamps and approves the document for UAE use." },
  { step: "05", title: "MOFA UAE Attestation", desc: "The UAE Ministry of Foreign Affairs gives final approval, making the document fully valid for official use across the UAE." },
]

const faqs = [
  { q: "Which personal documents need attestation in the UAE?", a: "Common personal documents requiring attestation include birth certificates, marriage certificates, divorce certificates, death certificates, medical certificates, affidavits, and transfer certificates — depending on your specific purpose in the UAE." },
  { q: "How long does personal document attestation take?", a: "The timeframe depends on the document type, country of origin, and authorities involved. Index Office Services manages the process efficiently and keeps you updated throughout." },
  { q: "Do I need to be present in the UAE for attestation?", a: "No. Index Office Services handles the complete process on your behalf. You can submit documents through our team or authorized courier arrangements without being physically present." },
  { q: "Does my document need to be translated before attestation?", a: "If your document is not in English or Arabic, certified translation may be required by UAE authorities. Our team will confirm whether this is necessary for your specific document." },
  { q: "What if my document has errors or is damaged?", a: "Documents with errors, unclear seals, or physical damage may be rejected during attestation. We review documents first and advise you on correction or reissuance before submitting." },
]
---

<BaseLayout title="Personal Documents Attestation in UAE — Index Office Services" description="Expert personal document attestation services in Dubai and Abu Dhabi. Birth, marriage, divorce, death certificate attestation — handled with 25+ years of experience.">

<style>
  .sec-inner { position: relative; z-index: 1; }
  .idx-pill { background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.28); color: #fff; font-size: 0.78rem; padding: 5px 14px; border-radius: 9999px; font-weight: 500; white-space: nowrap; }
  .idx-form input, .idx-form select, .idx-form textarea { width: 100%; border: 1px solid #e5e7eb; border-radius: 10px; padding: 11px 14px; font-size: 0.85rem; color: #374151; outline: none; font-family: inherit; background: #fff; box-sizing: border-box; }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus { border-color: #38B2AC; box-shadow: 0 0 0 3px rgba(56,178,172,0.15); }
  .idx-form textarea { resize: none; }
  .idx-submit { width: 100%; background: #2D3748; color: #fff; font-weight: 700; padding: 13px; border-radius: 10px; border: none; cursor: pointer; font-size: 0.95rem; letter-spacing: 0.04em; transition: background 0.2s; }
  .idx-submit:hover { background: #1A202C; }
  .svc-card { background: #fff; border: 1px solid #eef0f6; border-radius: 16px; padding: 24px; transition: all 0.25s; }
  .svc-card:hover { border-color: #B2F5EA; box-shadow: 0 12px 32px rgba(56,178,172,0.08); transform: translateY(-3px); }
  .step-card { display: flex; align-items: flex-start; gap: 16px; background: #fff; border: 1px solid #eef0f6; border-radius: 14px; padding: 18px; transition: all 0.25s; }
  .step-card:hover { border-color: #B2F5EA; box-shadow: 0 10px 24px rgba(56,178,172,0.08); }
  .faq-item { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; }
  .faq-q { width: 100%; background: #fff; border: none; text-align: left; padding: 18px 20px; font-size: 0.9rem; font-weight: 600; color: #1A202C; cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq-a { padding: 0 20px; max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s; }
  .faq-a.open { max-height: 200px; padding: 0 20px 16px; }
  .faq-icon { font-size: 1.1rem; transition: transform 0.3s; flex-shrink: 0; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }
  @media(max-width:768px){
    .about-hero-title { font-size: 2rem !important; }
    .split-grid { grid-template-columns: 1fr !important; gap: 32px !important; }
  }
</style>

<!-- ════════════ HERO ════════════ -->
<section style="position:relative;overflow:hidden;min-height:480px;display:flex;align-items:center;">
  <img
    src="https://images.unsplash.com/photo-1565793979993-f71bb65e8ca7?w=1600&q=80"
    alt="Personal Document Attestation UAE"
    style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
  />
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,32,44,0.90) 0%,rgba(45,55,72,0.82) 100%);"></div>
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1px,transparent 1px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:860px;margin:0 auto;padding:96px 24px;text-align:center;width:100%;">
    <div style="display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px;">
      <span class="idx-pill">Convenient</span>
      <span class="idx-pill">Budget-Friendly</span>
      <span class="idx-pill">25+ Yrs Experience</span>
      <span class="idx-pill">Genuine</span>
    </div>
    <h1 class="about-hero-title" style="font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.15;margin:0 0 20px;">
      PERSONAL DOCUMENTS<br/>ATTESTATION IN UAE
    </h1>
    <p style="color:#B2F5EA;font-size:1rem;line-height:1.8;margin:0 auto 32px;max-width:640px;">
      We handle attestation for birth, marriage, divorce, death, and all personal certificates — with clear guidance, careful processing, and 25 years of experience.
    </p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
      <a href="#get-in-touch" style="display:inline-flex;align-items:center;gap:8px;background:#38B2AC;color:#fff;font-weight:700;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;box-shadow:0 4px 20px rgba(56,178,172,0.4);">Get Free Consultation &rarr;</a>
      <a href="#details" style="display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.3);color:#fff;font-weight:600;font-size:0.9rem;padding:13px 28px;border-radius:9999px;text-decoration:none;">Learn More</a>
    </div>
  </div>
</section>

<!-- ════ OVERVIEW ════ -->
<section id="details" style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1.2fr 1fr;gap:52px;align-items:center;" class="split-grid">
    <div>
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;display:flex;align-items:center;gap:8px;margin-bottom:12px;">
        <span style="display:inline-block;width:28px;height:1px;background:#2D3748;"></span>Service Overview
      </p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#1A202C;line-height:1.2;margin:0 0 18px;">Why Personal Document Attestation Matters</h2>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        Personal documents issued outside the UAE must be officially verified before they can be accepted by UAE government departments, courts, embassies, and private institutions. Attestation confirms that your document is genuine and recognized under UAE law.
      </p>
      <p style="color:#4B5563;font-size:0.9rem;line-height:1.8;margin-bottom:14px;">
        From family visa applications to employment requirements and legal proceedings, attested personal documents are essential at key moments in your life. A missing or incomplete attestation can delay visas, block sponsorship applications, or hold up critical legal proceedings.
      </p>
      <div style="background:#F0FFFE;border:1px solid #B2F5EA;border-radius:12px;padding:18px;margin-top:24px;">
        <h3 style="color:#1A202C;font-size:0.95rem;font-weight:700;margin:0 0 6px;">Index Office Services — 25 Years of Experience</h3>
        <p style="color:#4B5563;font-size:0.85rem;line-height:1.75;margin:0;">
          Our team handles personal document attestation across all nationalities and countries, coordinating with home country authorities, UAE embassies, and MOFA for a smooth, verified process.
        </p>
      </div>
    </div>

    <div>
      <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,0.12);">
        <img src="https://images.unsplash.com/photo-1450101499163-c8848c66ca85?w=800&q=80" alt="Personal document attestation service" style="width:100%;height:400px;object-fit:cover;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(26,32,44,0.7) 100%);"></div>
        <div style="position:absolute;bottom:20px;left:20px;right:20px;">
          <p style="color:#fff;font-size:0.88rem;font-weight:800;margin:0 0 4px;">Trusted Across the UAE</p>
          <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Abu Dhabi · Dubai · GCC</p>
        </div>
        <div style="position:absolute;bottom:70px;left:-14px;background:#2D3748;color:#fff;padding:10px 16px;border-radius:10px;font-size:0.75rem;font-weight:700;box-shadow:0 6px 20px rgba(0,0,0,0.2);">
          25+ Years Experience
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ SERVICES GRID ════ -->
<section style="background:#F8FAFF;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(45,55,72,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(45,55,72,0.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;">
    <!-- Header with image accent -->
    <div style="display:grid;grid-template-columns:1.4fr 0.9fr;gap:48px;align-items:center;margin-bottom:52px;" class="split-grid">
      <div>
        <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">What We Attest</p>
        <h2 style="font-size:2rem;font-weight:900;color:#1A202C;margin:0 0 14px;">Personal Documents We Handle</h2>
        <p style="color:#4B5563;font-size:0.88rem;line-height:1.8;">We cover all common personal document types required for life in the UAE — from the moment you arrive to sponsoring your family.</p>
      </div>
      <div style="position:relative;border-radius:16px;overflow:hidden;box-shadow:0 12px 36px rgba(0,0,0,0.1);">
        <img src="https://images.unsplash.com/photo-1521791136064-7986c2920216?w=700&q=80" alt="Document attestation services Dubai" style="width:100%;height:220px;object-fit:cover;display:block;" />
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(26,32,44,0.65) 100%);"></div>
        <div style="position:absolute;bottom:14px;left:14px;right:14px;">
          <p style="color:#fff;font-size:0.8rem;font-weight:700;margin:0;">8 Personal Document Types</p>
        </div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:20px;">
      {services.map(s => (
        <div class="svc-card">
          <div style="font-size:2rem;margin-bottom:12px;">{s.icon}</div>
          <h3 style="font-size:0.92rem;font-weight:800;color:#1A202C;margin:0 0 8px;">{s.title}</h3>
          <p style="font-size:0.78rem;color:#4B5563;line-height:1.6;margin:0;">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════ STEP-BY-STEP PROCESS ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1200px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:52px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Authentication Workflow</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0 0 10px;">How Personal Document Attestation Works</h2>
      <p style="color:#6B7280;font-size:0.88rem;max-width:540px;margin:0 auto;">Each document follows a structured path from home country verification through to MOFA approval in the UAE.</p>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:start;" class="split-grid">
      <!-- Steps -->
      <div style="display:flex;flex-direction:column;gap:14px;">
        {steps.map(s => (
          <div class="step-card">
            <div style="width:42px;height:42px;border-radius:10px;background:#2D3748;color:#38B2AC;font-weight:900;font-size:0.85rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">{s.step}</div>
            <div>
              <p style="font-size:0.88rem;font-weight:700;color:#1A202C;margin:0 0 4px;">{s.title}</p>
              <p style="font-size:0.78rem;color:#6B7280;line-height:1.6;margin:0;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <!-- Image -->
      <div style="position:sticky;top:100px;">
        <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.12);">
          <img src="https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?w=700&q=80" alt="Attestation process steps" style="width:100%;height:480px;object-fit:cover;display:block;" />
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(26,32,44,0.78) 100%);"></div>
          <div style="position:absolute;bottom:20px;left:20px;right:20px;">
            <p style="color:#fff;font-size:0.95rem;font-weight:800;margin:0 0 4px;">End-to-End Process</p>
            <p style="color:#B2F5EA;font-size:0.78rem;margin:0;">From notarization to MOFA final approval</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ════ WHY CHOOSE US — DARK BANNER ════ -->
<section style="background:#1A202C;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.18) 1.5px,transparent 1.5px);background-size:28px 28px;pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:52px;align-items:center;" class="split-grid">
    <!-- Image -->
    <div style="position:relative;border-radius:20px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,0.3);">
      <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=700&q=80" alt="Index Office Services team UAE" style="width:100%;height:400px;object-fit:cover;display:block;" />
      <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(26,32,44,0.72) 100%);"></div>
      <div style="position:absolute;bottom:20px;left:20px;right:20px;">
        <p style="color:#fff;font-size:0.9rem;font-weight:800;margin:0 0 4px;">Index Office Services</p>
        <p style="color:#B2F5EA;font-size:0.75rem;margin:0;">Abu Dhabi &amp; Dubai · Est. 1999</p>
      </div>
    </div>
    <!-- Text -->
    <div>
      <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Our Strengths</p>
      <h2 style="font-size:clamp(1.7rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.2;margin:0 0 18px;">Why Choose Index Office Services?</h2>
      <p style="color:#B2F5EA;font-size:0.88rem;line-height:1.8;margin-bottom:24px;">
        A trusted company in the UAE with 25 years of experience in certificate attestation and company formation, offering clients efficient, compliant solutions across Abu Dhabi, Dubai, and the wider GCC region.
      </p>
      <div style="display:flex;flex-direction:column;gap:12px;">
        {[
          "Quick processing with structured updates at every stage",
          "Expert knowledge of UAE, GCC, and international legal requirements",
          "Strict confidentiality and secure physical document handling",
          "Doorstep courier pickup and delivery available across UAE",
          "Dedicated team support from submission to collection"
        ].map(item => (
          <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:10px;font-size:0.83rem;color:#E2E8F0;font-weight:500;">
            <span style="width:20px;height:20px;border-radius:50%;background:#38B2AC;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" width="10" height="10"><path d="M20 6L9 17l-5-5"/></svg>
            </span>
            {item}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ════ STATS ════ -->
<section style="background:#2D3748;padding:48px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(56,178,172,0.15) 1.5px,transparent 1.5px);background-size:24px 24px;pointer-events:none;z-index:0;"></div>
  <div class="sec-inner" style="max-width:860px;margin:0 auto;display:grid;grid-template-columns:repeat(2,1fr);gap:40px;text-align:center;">
    <div>
      <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">25,000+</p>
      <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Happy Customers</p>
    </div>
    <div>
      <p style="font-size:2.8rem;font-weight:900;color:#38B2AC;margin:0;">25+</p>
      <p style="color:#81E6D9;font-size:0.9rem;margin:6px 0 0;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;">Years of Experience</p>
    </div>
  </div>
</section>

<!-- ════ FAQ ════ -->
<section style="background:#fff;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:repeating-linear-gradient(135deg,transparent,transparent 48px,rgba(56,178,172,0.04) 48px,rgba(56,178,172,0.04) 49px);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:820px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:44px;">
      <p style="color:#2D3748;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:8px;">Got Questions?</p>
      <h2 style="font-size:2.2rem;font-weight:900;color:#1A202C;margin:0;">FREQUENTLY ASKED QUESTIONS</h2>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;">
      {faqs.map((f, i) => (
        <div class="faq-item">
          <button class="faq-q">
            <span>{i + 1}. {f.q}</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-a">
            <p style="color:#4B5563;font-size:0.875rem;line-height:1.75;margin:0;">{f.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ════════════ GET IN TOUCH ════════════ -->
<section id="get-in-touch" style="background:#2D3748;padding:76px 24px;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;z-index:0;"></div>
  <div style="position:absolute;top:0;left:50%;transform:translateX(-50%);width:600px;height:300px;background:radial-gradient(ellipse,rgba(56,178,172,0.12) 0%,transparent 70%);pointer-events:none;z-index:0;"></div>

  <div class="sec-inner" style="max-width:1100px;margin:0 auto;display:flex;flex-wrap:wrap;gap:52px;align-items:flex-start;">

    <div style="flex:1;min-width:280px;">
      <p style="color:#38B2AC;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;font-size:0.75rem;margin-bottom:12px;">Get In Touch</p>
      <h2 style="font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:#fff;line-height:1.25;margin:0 0 18px;">GET IN TOUCH WITH INDEX TODAY FOR ATTESTATION SERVICES.</h2>
      <p style="color:#B2F5EA;font-size:0.88rem;line-height:1.8;margin-bottom:16px;">Our extensive global network of service providers and offices allows us to seamlessly integrate our services and tailor them to meet your specific requirements.</p>
      <p style="color:#94A3B8;font-size:0.88rem;line-height:1.8;margin-bottom:28px;">If you require immediate assistance, you can also reach us using the contact numbers provided. We are available on WhatsApp via all of these numbers.</p>
