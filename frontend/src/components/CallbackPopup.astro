---
// CallbackPopup.astro
// A popup form that displays when a user first enters the website,
// styled to match the site's theme (teal/dark slate) and connected to Web3Forms.
---

<div id="callbackPopupOverlay" class="callback-popup-overlay">
  <div class="callback-popup-modal">
    <!-- Header with Gradient and Close Button -->
    <div class="callback-popup-header">
      <h3>Request a Call Back Now!</h3>
      <button id="closeCallbackPopupBtn" aria-label="Close dialog">&times;</button>
    </div>

    <!-- Modal Body -->
    <div class="callback-popup-body">
      <!-- Web3Forms Integration -->
      <form action="https://api.web3forms.com/submit" method="POST" id="callbackPopupForm">
        <!-- Change this to your Web3Forms access key later -->
        <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
        <input type="hidden" name="subject" value="New Call Back Request from Popup" />
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

        <!-- Form Fields -->
        <div class="form-group">
          <label for="popupName">Name</label>
          <input 
            type="text" 
            id="popupName" 
            name="name" 
            placeholder="Name" 
            required 
          />
        </div>

        <div class="form-group">
          <label for="popupContact">Contact</label>
          <input 
            type="text" 
            id="popupContact" 
            name="contact" 
            placeholder="Enter Your Contact Details (Phone/Email)" 
            required 
          />
        </div>

        <button type="submit" class="popup-submit-btn">Submit</button>
      </form>

      <!-- Action Buttons (WhatsApp, Call, Email) -->
      <div class="popup-action-buttons">
        <a 
          href="https://api.whatsapp.com/send/?phone=971529300200" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="action-btn whatsapp-btn"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          WHATSAPP US FOR INSTANT QUOTE
        </a>

        <a href="tel:+971529300200" class="action-btn call-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="margin-right:2px;"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          CALL US : (+971) 529 300 200
        </a>

        <div class="email-footer-note">
          Send us Email : <a href="mailto:info@indexauh.com">info@indexauh.com</a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Popup overlay */
  .callback-popup-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.65); /* Dark slate semi-transparent overlay */
    backdrop-filter: blur(4px);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    padding: 20px;
  }

  .callback-popup-overlay.show {
    opacity: 1;
    pointer-events: auto;
  }

  /* Modal Card */
  .callback-popup-modal {
    background: #ffffff;
    width: 100%;
    max-width: 420px;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    transform: translateY(30px) scale(0.95);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .callback-popup-overlay.show .callback-popup-modal {
    transform: translateY(0) scale(1);
  }

  /* Gradient Header */
  .callback-popup-header {
    background: linear-gradient(135deg, #1A202C 0%, #2D3748 100%);
    padding: 18px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 2px solid #38B2AC; /* Teal accent divider line */
  }

  .callback-popup-header h3 {
    color: #ffffff;
    font-size: 1.15rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: 0.02em;
  }

  .callback-popup-header button {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.85);
    font-size: 1.8rem;
    font-weight: 400;
    cursor: pointer;
    line-height: 1;
    padding: 0;
    margin: 0;
    transition: color 0.2s ease;
  }

  .callback-popup-header button:hover {
    color: #38B2AC; /* Hover to match website's teal theme */
  }

  /* Form Body */
  .callback-popup-body {
    padding: 24px 28px;
  }

  .form-group {
    margin-bottom: 16px;
    text-align: left;
  }

  .form-group label {
    display: block;
    font-size: 0.82rem;
    font-weight: 700;
    color: #2D3748;
    margin-bottom: 6px;
    text-transform: capitalize;
  }

  .form-group input {
    width: 100%;
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 0.9rem;
    color: #1A202C;
    outline: none;
    font-family: inherit;
    background: #FAFAFA;
    transition: all 0.2s ease;
    box-sizing: border-box;
  }

  .form-group input:focus {
    border-color: #38B2AC;
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(56, 178, 172, 0.15);
  }

  /* Submit Button */
  .popup-submit-btn {
    width: 100%;
    background: #38B2AC; /* Teal for high visibility */
    color: #ffffff;
    font-weight: 700;
    padding: 13px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    transition: background 0.2s ease;
    box-shadow: 0 4px 12px rgba(56, 178, 172, 0.25);
    margin-top: 6px;
    margin-bottom: 20px;
  }

  .popup-submit-btn:hover {
    background: #319795; /* Darker teal */
  }

  /* Action Buttons Section */
  .popup-action-buttons {
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-top: 1px solid #EDF2F7;
    padding-top: 20px;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    color: #ffffff;
    font-weight: 700;
    padding: 12px;
    border-radius: 10px;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    transition: background 0.2s ease;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    box-sizing: border-box;
  }

  .whatsapp-btn {
    background: #1A202C; /* Dark Slate background just like the user screenshot */
    border: 1px solid #2D3748;
  }

  .whatsapp-btn:hover {
    background: #25D366; /* Hover switches to WhatsApp Green */
    border-color: #25D366;
  }

  .call-btn {
    background: #1A202C; /* Matching Dark Slate */
    border: 1px solid #2D3748;
  }

  .call-btn:hover {
    background: #2D3748;
  }

  /* Email Note */
  .email-footer-note {
    background: #F7FAFC;
    border: 1px solid #EDF2F7;
    border-radius: 10px;
    padding: 8px;
    font-size: 0.8rem;
    color: #4A5568;
    text-align: center;
    margin-top: 4px;
  }

  .email-footer-note a {
    color: #38B2AC;
    font-weight: 700;
    text-decoration: none;
  }

  .email-footer-note a:hover {
    text-decoration: underline;
  }
</style>

<script>
  // Client-side execution code to trigger modal only on first entry
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('callbackPopupOverlay');
    const closeBtn = document.getElementById('closeCallbackPopupBtn');
    const form = document.getElementById('callbackPopupForm') as HTMLFormElement | null;

    if (!overlay || !closeBtn) return;

        // Check if the user has already seen the popup in sessionStorage
    const hasSeenPopup = sessionStorage.getItem('hasSeenCallbackPopup');

    if (!hasSeenPopup) {
      // Show the popup after a brief delay (1.5 seconds)
      setTimeout(() => {
        overlay.classList.add('show');
      }, 1500);
    }

    // Function to close the popup and store state in sessionStorage
    function closePopup() {
      overlay.classList.remove('show');
      sessionStorage.setItem('hasSeenCallbackPopup', 'true');
    }

    // Close on clicking 'X'
    closeBtn.addEventListener('click', closePopup);

    // Close on clicking outside the modal content
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) {
        closePopup();
      }
    });

    // Close on ESC key press
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('show')) {
        closePopup();
      }
    });

    // Form submission helper (closes popup and sets flag)
    if (form) {
      form.addEventListener('submit', () => {
        // We set the sessionStorage flag on submit so they don't see it again in the same session
        sessionStorage.setItem('hasSeenCallbackPopup', 'true');
        // Let the form submit naturally to Web3Forms
      });
    }
  });
</script>
