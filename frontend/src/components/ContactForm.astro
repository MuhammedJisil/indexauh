---
const countryCodes = [
  { code: "+971", label: "🇦🇪 AE +971" },
  { code: "+966", label: "🇸🇦 SA +966" },
  { code: "+974", label: "🇶🇦 QA +974" },
  { code: "+965", label: "🇰🇼 KW +965" },
  { code: "+968", label: "🇴🇲 OM +968" },
  { code: "+973", label: "🇧🇭 BH +973" },
  { code: "+91",  label: "🇮🇳 IN +91" },
  { code: "+44",  label: "🇬🇧 UK +44" },
  { code: "+1",   label: "🇺🇸 US +1" },
  { code: "+63",  label: "🇵🇭 PH +63" },
  { code: "+92",  label: "🇵🇰 PK +92" },
]
---
<form action="https://api.web3forms.com/submit" method="POST" class="idx-form" style="display:flex;flex-direction:column;gap:12px;">
  <!-- Replace with your actual Web3Forms Access Key -->
  <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE">

<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
  <div>
    <label style="display:block;font-size:0.7rem;font-weight:600;color:#9CA3AF;margin-bottom:3px;">Name</label>
    <input type="text" name="name" placeholder="Your Name*" required />
  </div>
  <div>
    <label style="display:block;font-size:0.7rem;font-weight:600;color:#9CA3AF;margin-bottom:3px;">Email</label>
    <input type="email" name="email" placeholder="Your Email Address*" required />
  </div>
</div>

<div style="display:flex;gap:10px;">
  <div style="width:120px;min-width:100px;flex-shrink:1;position:relative;">
    <label style="display:block;font-size:0.7rem;font-weight:600;color:#9CA3AF;margin-bottom:3px;">Code</label>
    <input type="hidden" name="country_code" id="ccHidden" value={countryCodes[0].code} />

    <button type="button" id="ccTrigger" style="width:100%;display:flex;align-items:center;justify-content:space-between;gap:8px;border:1px solid #e5e7eb;border-radius:10px;padding:11px 12px;background:#fff;cursor:pointer;font-size:0.85rem;color:#374151;font-family:inherit;">
      <span id="ccSelected" style="display:flex;align-items:center;gap:6px;overflow:hidden;">
        <span>{countryCodes[0].flag}</span><span>{countryCodes[0].code}</span>
      </span>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
    </button>

    <div id="ccPanel" style="display:none;position:absolute;top:calc(100% + 6px);left:0;width:280px;max-height:320px;background:#fff;border:1px solid #e5e7eb;border-radius:12px;box-shadow:0 12px 40px rgba(0,0,0,0.15);z-index:50;overflow:hidden;">
      <div style="padding:10px;border-bottom:1px solid #f0f0f0;">
        <input type="text" id="ccSearch" placeholder="Search country..." style="width:100%;border:1px solid #e5e7eb;border-radius:8px;padding:8px 10px;font-size:0.85rem;outline:none;box-sizing:border-box;" />
      </div>
      <div id="ccList" style="max-height:250px;overflow-y:auto;"></div>
    </div>
  </div>

  <div style="flex:1;min-width:0;">
    <label style="display:block;font-size:0.7rem;font-weight:600;color:#9CA3AF;margin-bottom:3px;">Phone</label>
    <input type="tel" name="phone" placeholder="Phone Number*" required />
  </div>
</div>
  <div>
    <label style="display:block;font-size:0.7rem;font-weight:600;color:#9CA3AF;margin-bottom:3px;">Service</label>
    <select name="service" required>
      <option value="">Select a Service</option>
      <option>Company Formation</option>
      <option>PRO Services</option>
      <option>Attestation / Legalization / Apostille</option>
      <option>PCC (Good Standing Certificate)</option>
      <option>Legal Translation Services</option>
      <option>PAN Card Services</option>
      <option>Credential Evaluation Services</option>
      <option>Other Services</option>
    </select>
  </div>
  <div>
    <label style="display:block;font-size:0.7rem;font-weight:600;color:#9CA3AF;margin-bottom:3px;">Message</label>
    <textarea name="message" placeholder="Enter your message*" rows="3" required></textarea>
  </div>

  <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

  <button type="submit" class="idx-submit" id="idxSubmitBtn">Submit</button>
</form>

<!-- ══ Themed Success Popup ══ -->
<div id="idxSuccessOverlay" style="display:none;position:fixed;inset:0;background:rgba(26,32,44,0.6);z-index:9999;align-items:center;justify-content:center;padding:24px;">
  <div style="background:#fff;border-radius:20px;max-width:420px;width:100%;padding:36px 28px;text-align:center;box-shadow:0 24px 60px rgba(0,0,0,0.3);position:relative;">
    <div style="width:64px;height:64px;background:#F0FFFE;border:2px solid #38B2AC;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#38B2AC" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </div>
    <h3 style="font-size:1.25rem;font-weight:800;color:#1A202C;margin:0 0 10px;">Thank You!</h3>
    <p style="font-size:0.95rem;color:#6B7280;line-height:1.6;margin:0 0 24px;">Your request has been submitted successfully. Our team will get back to you shortly.</p>
    <button id="idxCloseSuccess" style="background:#2D3748;color:#fff;font-weight:700;padding:11px 28px;border-radius:9999px;border:none;cursor:pointer;font-size:0.9rem;">Close</button>
  </div>
</div>

<!-- ══ Themed Error Popup ══ -->
<div id="idxErrorOverlay" style="display:none;position:fixed;inset:0;background:rgba(26,32,44,0.6);z-index:9999;align-items:center;justify-content:center;padding:24px;">
  <div style="background:#fff;border-radius:20px;max-width:420px;width:100%;padding:36px 28px;text-align:center;box-shadow:0 24px 60px rgba(0,0,0,0.3);">
    <div style="width:64px;height:64px;background:#FEF2F2;border:2px solid #EF4444;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 18px;">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18L18 6M6 6l12 12"/></svg>
    </div>
    <h3 style="font-size:1.25rem;font-weight:800;color:#1A202C;margin:0 0 10px;">Something Went Wrong</h3>
    <p style="font-size:0.95rem;color:#6B7280;line-height:1.6;margin:0 0 24px;">We couldn't submit your request. Please try again or contact us directly.</p>
    <button id="idxCloseError" style="background:#2D3748;color:#fff;font-weight:700;padding:11px 28px;border-radius:9999px;border:none;cursor:pointer;font-size:0.9rem;">Close</button>
  </div>
</div>

<style>
  .idx-form input,.idx-form select,.idx-form textarea{width:100%;border:1px solid #e5e7eb;border-radius:10px;padding:11px 14px;font-size:0.85rem;color:#374151;outline:none;font-family:inherit;background:#fff;box-sizing:border-box;}
  .idx-form input:focus,.idx-form select:focus,.idx-form textarea:focus{border-color:#38B2AC;box-shadow:0 0 0 3px rgba(56,178,172,0.15);}
  .idx-form textarea{resize:none;}
  .idx-submit{width:100%;background:#2D3748;color:#fff;font-weight:700;padding:13px;border-radius:10px;border:none;cursor:pointer;font-size:0.95rem;letter-spacing:0.04em;transition:background 0.2s;}
  .idx-submit:hover{background:#1A202C;}
  .idx-submit:disabled{opacity:0.6;cursor:not-allowed;}
 @media(max-width:400px){
  #ccTrigger { padding: 11px 6px; font-size: 0.78rem; }
}
</style>

<script define:vars={{ countryCodes }}>
(function(){
  const trigger  = document.getElementById('ccTrigger');
  const panel    = document.getElementById('ccPanel');
  const list     = document.getElementById('ccList');
  const search   = document.getElementById('ccSearch');
  const hidden   = document.getElementById('ccHidden');
  const selected = document.getElementById('ccSelected');

  function renderList(filter = '') {
    const f = filter.trim().toLowerCase();
    const items = countryCodes.filter(c =>
      c.name.toLowerCase().includes(f) || c.code.includes(f)
    );
    list.innerHTML = items.map(c => `
      <div class="cc-item" data-code="${c.code}" data-flag="${c.flag}"
        style="display:flex;align-items:center;gap:10px;padding:9px 14px;cursor:pointer;font-size:0.88rem;color:#1A202C;">
        <span style="font-size:1.1rem;">${c.flag}</span>
        <span style="flex:1;">${c.name}</span>
        <span style="color:#6B7280;font-size:0.82rem;">${c.code}</span>
      </div>
    `).join('') || `<div style="padding:14px;color:#9CA3AF;font-size:0.85rem;">No results</div>`;

    list.querySelectorAll('.cc-item').forEach(el => {
      el.addEventListener('mouseenter', () => el.style.background = '#F0FFFE');
      el.addEventListener('mouseleave', () => el.style.background = 'transparent');
      el.addEventListener('click', () => {
        hidden.value = el.dataset.code;
        selected.innerHTML = `<span>${el.dataset.flag}</span><span>${el.dataset.code}</span>`;
        panel.style.display = 'none';
      });
    });
  }

  trigger?.addEventListener('click', () => {
    const isOpen = panel.style.display === 'block';
    panel.style.display = isOpen ? 'none' : 'block';
    if (!isOpen) { renderList(); search.value = ''; search.focus(); }
  });

  search?.addEventListener('input', () => renderList(search.value));

  document.addEventListener('click', (e) => {
    if (!e.target.closest('#ccTrigger') && !e.target.closest('#ccPanel')) {
      panel.style.display = 'none';
    }
  });
})();
</script>

<script>
  const form = document.getElementById('idxContactForm');
  const submitBtn = document.getElementById('idxSubmitBtn');
  const successOverlay = document.getElementById('idxSuccessOverlay');
  const errorOverlay = document.getElementById('idxErrorOverlay');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const originalText = submitBtn.textContent;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
        },
        body: json,
      });
      const result = await res.json();

      if (res.status === 200 && result.success) {
        form.reset(); // clears all fields
        successOverlay.style.display = 'flex';
      } else {
        errorOverlay.style.display = 'flex';
      }
    } catch (err) {
      errorOverlay.style.display = 'flex';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });

  document.getElementById('idxCloseSuccess')?.addEventListener('click', () => {
    successOverlay.style.display = 'none';
  });
  document.getElementById('idxCloseError')?.addEventListener('click', () => {
    errorOverlay.style.display = 'none';
  });
</script>

<style>
  .idx-form input, .idx-form select, .idx-form textarea {
    width: 100%;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 11px 14px;
    font-size: 0.85rem;
    color: #374151;
    outline: none;
    font-family: inherit;
    background: #fff;
    box-sizing: border-box;
  }
  .idx-form input:focus, .idx-form select:focus, .idx-form textarea:focus {
    border-color: #38B2AC;
    box-shadow: 0 0 0 3px rgba(56,178,172,0.15);
  }
  .idx-form textarea {
    resize: none;
  }
  .idx-submit {
    width: 100%;
    background: #2D3748;
    color: #fff;
    font-weight: 700;
    padding: 13px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    transition: background 0.2s;
  }
  .idx-submit:hover {
    background: #1A202C;
  }
</style>
